generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password_hash String
  name          String?
  organizations Organization[]
  createdAt     DateTime       @default(now())
  active_org_id String?
}

model Organization {
  id               String          @id @default(uuid())
  name             String
  inn              String?
  user_id          String
  user             User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  accounts         Account[]
  counterparties   Counterparty[]
  transactions     Transaction[]
  settings         SystemSettings[]
  template_id      String?
  onboarding_state OnboardingState @default(COMPLETED)
  onboarding_step  Int             @default(1)
  ai_description   String?
  template         IndustryTemplate? @relation(fields: [template_id], references: [id])
  subscription     Subscription?
  auditLogs        AuditLog[]
  chatMessages     ChatMessage[]
  aiUsages         AiUsage[]
  payments         Payment[]
}

model Account {
  id                String        @id @default(uuid())
  code              String
  name              String
  type              AccountType
  organization_id   String
  organization      Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  transactions_dr   Transaction[] @relation("DebitAccount")
  transactions_cr   Transaction[] @relation("CreditAccount")
  master_account_id String?
  is_active         Boolean       @default(true)
  is_custom         Boolean       @default(false)
  master_account    MasterAccount? @relation(fields: [master_account_id], references: [id])

  @@unique([code, organization_id])
}

model Counterparty {
  id              String        @id @default(uuid())
  name            String
  inn             String?
  organization_id String
  organization    Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  transactions    Transaction[]
}

model Transaction {
  id              String       @id @default(uuid())
  date            DateTime
  period          String // Format: MM.YYYY (for reporting)
  description     String
  amount          Decimal      @db.Decimal(20, 2)
  debit_id        String
  credit_id       String
  counterparty_id String?
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  is_deleted      Boolean      @default(false)
  createdAt       DateTime     @default(now())
  debit           Account      @relation("DebitAccount", fields: [debit_id], references: [id])
  credit          Account      @relation("CreditAccount", fields: [credit_id], references: [id])
  counterparty    Counterparty? @relation(fields: [counterparty_id], references: [id])

  @@index([date])
  @@index([period])
  @@index([debit_id])
  @@index([credit_id])
  @@index([counterparty_id])
  @@index([organization_id])
}

model SystemSettings {
  id                       String       @id @default(uuid())
  closed_period_date       DateTime
  opening_balance_date     DateTime     @default("2025-01-01T00:00:00Z")
  is_initial_balance_fixed Boolean      @default(false)
  organization_id          String       @unique
  organization             Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
}

model MasterAccount {
  id          String               @id @default(uuid())
  code        String               @unique
  name        String
  type        AccountType
  description String?
  section     String?
  is_system   Boolean              @default(false)
  sort_order  Int                  @default(0)
  template_items IndustryTemplateItem[]
  accounts    Account[]
}

model IndustryTemplate {
  id          String                 @id @default(uuid())
  key         String                 @unique
  name        String
  description String?
  is_active   Boolean                @default(true)
  sort_order  Int                    @default(0)
  items       IndustryTemplateItem[]
  organizations Organization[]
}

model IndustryTemplateItem {
  id                String           @id @default(uuid())
  template_id       String
  master_account_id String
  is_required       Boolean          @default(false)
  template          IndustryTemplate @relation(fields: [template_id], references: [id])
  master_account    MasterAccount    @relation(fields: [master_account_id], references: [id])

  @@unique([template_id, master_account_id])
}

model AuditLog {
  id              String   @id @default(uuid())
  organization_id String
  user_id         String
  action          String
  entity_type     String?
  entity_id       String?
  payload         Json?
  ip_address      String?
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at      DateTime @default(now())

  @@index([organization_id])
  @@index([created_at])
}

model ChatMessage {
  id              String   @id @default(uuid())
  organization_id String
  user_id         String
  role            String
  content         String
  tokens_used     Int?
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at      DateTime @default(now())

  @@index([organization_id])
  @@index([created_at])
}

model AiUsage {
  id              String   @id @default(uuid())
  organization_id String
  user_id         String
  feature         String
  tokens_input    Int
  tokens_output   Int
  cost_usd        Decimal  @db.Decimal(10, 6)
  duration_ms     Int?
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  created_at      DateTime @default(now())

  @@index([organization_id, created_at])
}

enum OnboardingState {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum AccountType {
  ACTIVE
  CONTRA_ACTIVE
  PASSIVE
  CONTRA_PASSIVE
  TRANSIT
  OFF_BALANCE
  ACTIVE_PASSIVE
}

model Subscription {
  id              String       @id @default(uuid())
  organization_id String       @unique
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  
  plan            PlanType     @default(FREE)
  valid_until     DateTime?    // Null for FREE, specific date for PRO
  
  custom_api_key  String?
  
  updated_at      DateTime     @updatedAt
}

model Payment {
  id                  String        @id @default(uuid())
  organization_id     String
  organization        Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  amount              Decimal       @db.Decimal(20, 2)
  amount_tiyin        BigInt?
  provider            PaymentProvider 
  external_id         String?       @unique
  status              PaymentStatus @default(PENDING)
  processing_status   String?       // e.g. "PROCESSING"
  cancel_reason       String?
  cancel_time         DateTime?
  paid_at             DateTime?
  created_at          DateTime      @default(now())

  @@index([organization_id])
}

model PaymentConfig {
  id                String   @id @default("default")
  payme_merchant_id String?
  payme_key         String?
  payme_test_key    String?
  payme_env         String   @default("test")
  click_merchant_id String?
  click_service_id  String?
  click_secret_key  String?
  click_env         String   @default("test")
  pro_price_yearly  Int      @default(299000)
  updated_at        DateTime @updatedAt
}

model Voucher {
  id              String    @id @default(uuid())
  code            String    @unique
  days_granted    Int       @default(30)
  is_used         Boolean   @default(false)
  used_by_org_id  String?   
  activated_at    DateTime?
  created_at      DateTime  @default(now())
}

enum PlanType {
  FREE
  PRO
  MYAPI
}

enum PaymentProvider {
  PAYME
  CLICK
  VOUCHER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}
